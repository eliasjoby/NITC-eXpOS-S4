int main(){
    decl
        int temp,num,val;
    enddecl

    begin
        num=1;
        while(num<=100)do
            val=num%2;
            if(val!=0)then
                write(num);//or temp=exposcall("Write",-2,num); //both will push "Write" onto the stack according to the ABI convention
            endif;
            num=num+1;
        endwhile;
        return 0;
    end
}
//Process Manager module

alias fxnNum R1;
alias pid R2;

if(fxnNum==2)then //FREE_USER_AREA_PAGE
    alias uAreaPgNo R5;
    uAreaPgNo=[PROCESS_TABLE + 16*pid + 11];

    //release page to Resource manager module
    multipush(R1,R2,R5);
    R1=RELEASE_PAGE;
    R2=uAreaPgNo;

    call MOD_2;
    multipop(R1,R2,R5);
    return;
endif;

if(fxnNum==3)then //EXIT_PROCESS

    //call Free Page Table from Process manager
    multipush(R1,R2,R5);
    R1=FREE_PAGE_TABLE;
    R2=pid;
    call MOD_1;
    multipop(R1,R2,R5);

    //call Free User Area page from Process manager
    multipush(R1,R2,R5);
    R1=FREE_USER_AREA_PAGE;
    R2=pid;
    call MOD_1;
    multipop(R1,R2,R5);

    [PROCESS_TABLE + 16*pid + 4]=TERMINATED;
    return;
endif;

if(fxnNum==4)then //FREE_PAGE_TABLE
    alias ptbr_currProcess R7;
    alias i R6;

    ptbr_currProcess=[PROCESS_TABLE+16*pid + 14];

    i=0;
    while(i<=1)do
        [ptbr_currProcess + 2*i]=-1;
        [ptbr_currProcess + 2*i+1]="0000";
        i=i+1;
    endwhile;

    i=4;
    while(i<20)do
        if([ptbr_currProcess + i]!=-1)then
            multipush(R1,R2,R3,R4,R5,R6,R7);
            R1=RELEASE_PAGE;
            R2=[ptbr_currProcess+i];
            call MOD_2;
            multipop(R1,R2,R3,R4,R5,R6,R7);
            [ptbr_currProcess + i]=-1;
            [ptbr_currProcess + i+1]="0000";
        endif;
        i=i+2;
    endwhile;
    return;
endif;
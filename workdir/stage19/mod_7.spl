//set the remaining process table structures to terminated

[PROCESS_TABLE + 2*16 + 4]=TERMINATED;
[PROCESS_TABLE + 3*16 + 4]=TERMINATED;
[PROCESS_TABLE + 4*16 + 4]=TERMINATED;
[PROCESS_TABLE + 5*16 + 4]=TERMINATED;

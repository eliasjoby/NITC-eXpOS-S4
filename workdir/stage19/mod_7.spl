loadi(61,2);

//-------------------------------------------------------

//INIT code

//76,77-heap
//78,79-stack
//80-UArea pg no

PTBR=PAGE_TABLE_BASE+20;
PTLR=10;

[PTBR+0]=63;
[PTBR+1]="0100";
[PTBR+2]=64;
[PTBR+3]="0100";

[PTBR+4]=76;
[PTBR+5]="0110";
[PTBR+6]=77;
[PTBR+7]="0110";

[PTBR+8]=65;
[PTBR+9]="0100";
[PTBR+10]=66;
[PTBR+11]="0100";
[PTBR+12]=-1;
[PTBR+13]="0000";
[PTBR+14]=-1;
[PTBR+15]="0000";

[PTBR+16]=78;
[PTBR+17]="0110";
[PTBR+18]=79;
[PTBR+19]="0110";

[78*512]=[65*512+1];

//----------------------------------------------------
//set Process tbl -> pid, UArea Pg No,state,UPTR

alias init_process_tbl R10;
init_process_tbl=PROCESS_TABLE+16;

[init_process_tbl+ 1]=1;
[init_process_tbl+ 4]=CREATED;
[init_process_tbl+ 11]=80;
[init_process_tbl+ 12]=0;
[init_process_tbl+ 13]=8*512;
[init_process_tbl+ 14]=PTBR;
[init_process_tbl+ 15]=10;

//-----------------------------------------------------

//initialise per-process resource tbl for init

//allot the last 16 words -> 8 entries of 2 words each

multipush(R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11,R12);
alias j R11;
j=0;
alias i R12;

i=(80+1)*512-1;
while(j<16)do
    [i-j]=-1;
    j=j+1;
endwhile;

multipop(R0,R1,R2,R3,R4,R5,R6,R7,R8,R9,R10,R11,R12);

//--------------------------------------------------

//disk_map_tbl for init process
[DISK_MAP_TABLE +10*1 +0]=80;//user area pg
[DISK_MAP_TABLE +10*1 +1]=-1;
[DISK_MAP_TABLE + 10*1 + 2] = 76; //Heap
[DISK_MAP_TABLE + 10*1 + 3] = 77;
[DISK_MAP_TABLE + 10*1 + 4] = 7; //code
[DISK_MAP_TABLE + 10*1 + 5] = 8;
[DISK_MAP_TABLE + 10*1 + 6] = -1;
[DISK_MAP_TABLE + 10*1 + 7] = -1;
[DISK_MAP_TABLE + 10*1 + 8] = 78; //stack
[DISK_MAP_TABLE + 10*1 + 9] = 79;


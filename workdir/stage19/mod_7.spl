//-----------------

//initialise memory free list

i=0;
while(i<MAX_MEM_PAGE)do
    if(i<=94)then   
        [MEMORY_FREE_LIST+i]=1;
    else
        [MEMORY_FREE_LIST+i]=0;
    endif;
    i=i+1;
endwhile;

//Wait_mem_count and Mem_free_count

[SYSTEM_STATUS_TABLE + 3]=0;
[SYSTEM_STATUS_TABLE + 2]=(127-95+1);//

//-----------------
[TERMINAL_STATUS_TABLE]=0;
[DISK_STATUS_TABLE]=0;

return;

int main(){
    decl
        int temp,num;
    enddecl

    begin
        num=1;
        while(num<=50)do
            write(num);//or temp=exposcall("Write",-2,num); //both will push "Write" onto the stack according to the ABI convention
            num=num+5;
        endwhile;
        return 0;
    end
}
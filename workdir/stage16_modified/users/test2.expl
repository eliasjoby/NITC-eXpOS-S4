decl
    str arr[10];
enddecl

int main(){
    decl
        int i,j,temp;
        str bruh;
    enddecl

    begin
        j=0;
        while(j<10)do
            bruh="read arr2: ";
            write(bruh);
            read(arr[j]);
            j=j+1;
        endwhile;

        bruh="PRINT_arr2: ";
        write(bruh);
        j=0;
        while(j<10)do
            bruh="write arr2: ";
            write(bruh);
            write(arr[j]);
            j=j+1;
        endwhile;

        return 0;
    end
}